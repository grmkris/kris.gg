# Google Gemini API key — used by the photo curation pipeline (scripts/photos/curate.ts).
# Get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional Gemini model override for curation (default: gemini-3.5-flash).
# Falls back to gemini-2.5-flash / gemini-2.0-flash if the id doesn't resolve.
GEMINI_MODEL=gemini-3.5-flash
