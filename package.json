{
  "name": "agent-next-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun next dev --port 3001",
    "build": "bun --bun next build",
    "photos:mine": "bun run scripts/photos/mine.ts",
    "photos:itinerary": "bun run scripts/photos/itinerary.ts",
    "photos:curate": "bun run scripts/photos/curate.ts",
    "photos:review": "bun run scripts/photos/review.ts",
    "photos:place": "bun run scripts/photos/place.ts",
    "photos:publish": "bun run scripts/photos/publish.ts",
    "start": "bun --bun next start",
    "typecheck": "tsc --noEmit",
    "fix": "ultracite fix --type-aware --type-check",
    "fix:unsafe": "ultracite fix --unsafe --type-aware --type-check",
    "test": "bun test",
    "verify": "bun run typecheck && bun run fix && bun run test"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.563.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.3",
    "recharts": "2.15.4",
    "shadcn": "^3.6.2",
    "shiki": "^4.1.0",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.4",
    "yet-another-react-lightbox": "^3.32.0"
  },
  "devDependencies": {
    "@ai-sdk/google": "^3.0.83",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/bun": "^1.3.6",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "ai": "^6.0.207",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "^0.11.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.10",
    "typescript": "^5",
    "ultracite": "7.0.12"
  },
  "packageManager": "bun@1.3.5"
}
